# Graylog AI Summary – environment variables (for testing)
# Copy to .env and fill in your values.
# .env is gitignored.

# Graylog
GRAYLOG_BASE_URL=https://graylog.example.com
GRAYLOG_API_TOKEN=your_graylog_api_token
GRAYLOG_STREAM_ID=your_stream_id

# LLM backend selection
# LLM_PROVIDER can be "ollama" (default) or "lmstudio"
# LLM_PROVIDER=lmstudio

# Ollama (optional: overrides config.yaml)
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=qwen2.5:72b
OLLAMA_BEARER_TOKEN=your_ollama_bearer_token

# LM Studio (optional: overrides config.yaml)
# LMSTUDIO_BASE_URL=http://localhost:1234
# LMSTUDIO_MODEL=qwen2.5:32b-instruct
# LMSTUDIO_API_KEY=your_lmstudio_api_key_if_configured

# Optional: Telegram (overrides config.yaml)
# TELEGRAM_BOT_TOKEN=123456:ABC...
# TELEGRAM_CHAT_ID=123456789

# Summary: language and which logs to include
SUMMARY_LANGUAGE=de
# SUMMARY_ERROR_LEVELS=all          # all levels 0–7; or e.g. 0,1,2,3 for Emergency/Alert/Critical/Error only
# SUMMARY_SECURITY_KEYWORDS=unauthorized,login failed,invalid token   # empty = no security search

# Optional: Slack (if set, also sent in addition to Telegram)
# SLACK_WEBHOOK_URL=https://hooks.slack.com/services/YOUR/WEBHOOK/PATH
